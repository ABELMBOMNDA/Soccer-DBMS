{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Start Backend (Node/Express)",
            "program": "${workspaceFolder}/web/backend/server.js",
            "cwd": "${workspaceFolder}/web/backend",
            "envFile": "${workspaceFolder}/web/backend/.env",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Open in Chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/web/frontend/src"
        },
    ],
    "compounds": [
        {
            "name": "Run Full Stack + Chrome",
            "configurations": ["Start Backend (Node/Express)", "Open in Chrome"]
        }
    ]
}
