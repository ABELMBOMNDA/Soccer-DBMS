{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}/web/backend"
            },
            "group": "build",
            "presentation": {
                "panel": "new",
                "reveal": "always",
                "group": "epl"
            },
            "isBackground": true
        },
        {
            "label": "Start Frontend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/web/frontend"
            },
            "group": "build",
            "presentation": {
                "panel": "new",
                "reveal": "always",
                "group": "epl"
            },
            "isBackground": true
        },
        {
            "label": "Open in Chrome",
            "type": "shell",
            "command": "sleep 3 && open -a 'Google Chrome' http://localhost:3000",
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Open in Safari",
            "type": "shell",
            "command": "sleep 3 && open -a Safari http://localhost:3000",
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Open in Both Browsers",
            "type": "shell",
            "command": "sleep 3 && open -a 'Google Chrome' http://localhost:3000 && open -a Safari http://localhost:3000",
            "presentation": { "reveal": "silent", "panel": "shared" }
        },
        {
            "label": "Start Full Stack",
            "dependsOn": ["Start Backend", "Start Frontend"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Start Full Stack + Open Both Browsers",
            "dependsOn": ["Start Backend", "Start Frontend", "Open in Both Browsers"],
            "group": "build"
        }
    ]
}
